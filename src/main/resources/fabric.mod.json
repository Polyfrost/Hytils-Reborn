{
	"schemaVersion": 1,
	"id": "${mod_id}",
	"version": "${mod_version}",
	"name": "${mod_name}",
	"description": "${mod_description}",
	"authors": [
		"Polyfrost"
	],
	"contact": {
		"issues": "https://github.com/Polyfrost/${mod_id}/issues",
		"sources": "https://github.com/Polyfrost/${mod_id}"
	},
	"license": "GPL-3.0-or-later",
	"environment": "client",
	"entrypoints": {
		"client": [
			{
				"adapter": "kotlin",
				"value": "org.polyfrost.hytils.HytilsRebornEntrypoint"
			}
		]
	},
	"mixins": [
		"mixins.hytils.json"
	],
	"depends": {
		"minecraft": "${mc_compat}",
		"fabricloader": ">=0.17",
		"oneconfigv1": ">=${oneconfig_version}",
		"fabric-api": "*",
		"fabric-language-kotlin": "*",
		"hypixel-mod-api": "*"
	}
}
